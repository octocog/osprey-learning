---
import '../styles/global.css';
import Logo from '../components/Logo.astro';

const base = import.meta.env.BASE_URL;
const img = (name: string) => `${base}images/${name}`;

const SITE_TITLE = 'Osprey Learning Group — K–4 Reading, Math & Writing Tutoring';
const SITE_DESC =
  'Specialized one-on-one and small-group tutoring for K–4 students. Personalized, research-backed instruction in reading, math, and writing from a certified educator with 17+ years of experience.';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(`${base}og.png`, Astro.site);

// Placeholder — replace with the family's real contact details.
const CONTACT_EMAIL = 'hello@ospreylearning.com';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={SITE_DESC} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{SITE_TITLE}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Osprey Learning Group" />
    <meta property="og:title" content={SITE_TITLE} />
    <meta property="og:description" content={SITE_DESC} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={SITE_TITLE} />
    <meta name="twitter:description" content={SITE_DESC} />
    <meta name="twitter:image" content={ogImageURL} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="nav">
      <div class="nav__inner">
        <a class="brand" href="#top"><span class="mark"><Logo /></span> Osprey Learning Group</a>
        <nav aria-label="Primary">
          <ul class="nav__links">
            <li><a href="#services">Services</a></li>
            <li><a href="#approach">Our Approach</a></li>
            <li><a href="#founder">About Nell</a></li>
            <li><a href="#contact">Contact</a></li>
          </ul>
        </nav>
        <a class="btn btn--primary nav__cta" href="#contact">Free Consultation</a>
      </div>
    </header>

    <main id="main">
      <span id="top"></span>

      <!-- ===================== HERO ===================== -->
      <section class="hero">
        <div class="container hero__grid">
          <div class="hero__copy">
            <p class="eyebrow" data-reveal>K–4 Tutoring · Personalized &amp; research-backed</p>
            <h1 data-reveal data-delay="1">
              Confidence and skills to succeed&nbsp;— <em>in school and beyond.</em>
            </h1>
            <p class="lead" data-reveal data-delay="2">
              Osprey Learning Group offers specialized one-on-one and small-group tutoring in
              reading, math, and writing — meeting each child where they are and guiding them
              forward, one step at a time.
            </p>
            <div class="hero__cta" data-reveal data-delay="3">
              <a class="btn btn--primary" href="#contact">Book a free consultation</a>
              <a class="btn btn--ghost" href="#services">Explore our services</a>
            </div>
            <div class="hero__trust" data-reveal data-delay="3">
              <span><i class="dot"></i> 17+ years teaching K–4</span>
              <span><i class="dot"></i> Columbia Teachers College, TESOL</span>
              <span><i class="dot"></i> Certified educator</span>
            </div>
          </div>

          <div class="hero__media" data-reveal data-delay="2">
            <img class="hero__photo" src={img('hero.jpg')} width="700" height="756"
              alt="A young student reading a book at a table with letter tiles and colorful books" />
            <div class="hero__badge">
              <span class="num">17+</span>
              <span class="lbl">years of classroom<br />experience</span>
            </div>
          </div>
        </div>
      </section>

      <svg class="wave" viewBox="0 0 1440 90" preserveAspectRatio="none" aria-hidden="true" style="color: var(--sand)">
        <path fill="currentColor" d="M0,40 C240,90 480,90 720,55 C960,20 1200,20 1440,55 L1440,90 L0,90 Z" />
      </svg>

      <!-- ===================== APPROACH / PHILOSOPHY ===================== -->
      <section class="philosophy section-pad" id="approach">
        <div class="container philosophy__grid">
          <div class="philosophy__media" data-reveal>
            <img src={img('together.jpg')} width="500" height="625"
              alt="Two children reading a book together at a table in warm afternoon light" />
          </div>
          <div class="philosophy__text">
            <p class="eyebrow" data-reveal>Our Approach</p>
            <p class="statement" data-reveal data-delay="1">
              We believe every child deserves the <b>confidence and skills to succeed</b> — in
              school and in life.
            </p>
            <p class="lead" data-reveal data-delay="2">
              Our specialized tutoring meets each learner exactly where they are and guides them
              forward with personalized, research-backed instruction — building real skills and
              genuine confidence along the way.
            </p>
            <dl class="mini-stats" data-reveal data-delay="2">
              <div><dt>1:1</dt><dd>&amp; small-group options</dd></div>
              <div><dt>Custom</dt><dd>learning plans for each child</dd></div>
              <div><dt>K–4</dt><dd>early-learner specialists</dd></div>
            </dl>
          </div>
        </div>
      </section>

      <!-- ===================== SERVICES ===================== -->
      <section class="services section-pad" id="services">
        <div class="container">
          <div class="services__head">
            <div class="section-head">
              <p class="eyebrow" data-reveal>What we offer</p>
              <h2 data-reveal data-delay="1">Our Services</h2>
            </div>
            <p class="lead" data-reveal data-delay="1" style="max-width: 26rem; margin-top:0;">
              Tailored support across the three foundations of early learning.
            </p>
          </div>

          <div class="cards">
            <!-- Reading -->
            <article class="card" data-reveal>
              <div class="card__media">
                <img src={img('service-reading.jpg')} width="400" height="275"
                  alt="A child reading a picture book by a sunlit window" />
              </div>
              <div class="card__body">
                <span class="card__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6.5C10.5 5 8 4.5 4 4.75V18.5c4-.25 6.5.25 8 1.75 1.5-1.5 4-2 8-1.75V4.75C16 4.5 13.5 5 12 6.5Z"/><path d="M12 6.5V20.25"/></svg>
                </span>
                <h3>Reading Support</h3>
                <p class="card__intro">We help students build strong foundations in:</p>
                <ul class="skill-list">
                  <li><b>Encoding &amp; Decoding</b> — strengthening phonics, sound-symbol relationships, and word recognition.</li>
                  <li><b>Reading Comprehension</b> — strategies to understand, retain, and engage with texts across genres.</li>
                </ul>
                <p class="card__foot">
                  Whether your child is just learning to read or struggling to keep up, we offer
                  tailored support that builds confidence and skills — one step at a time.
                </p>
              </div>
            </article>

            <!-- Math -->
            <article class="card" data-reveal data-delay="1">
              <div class="card__media">
                <img src={img('service-math.jpg')} width="400" height="275"
                  alt="A child holding number cards in a bright classroom" />
              </div>
              <div class="card__body">
                <span class="card__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3.5" y="3.5" width="17" height="17" rx="2.5"/><path d="M7 8h4M9 6v4M14 8h3M7 15.5h3M14 14.5h3M14 16.5h3"/><path d="m13.8 6.2 2.4 2.4M16.2 6.2l-2.4 2.4"/></svg>
                </span>
                <h3>Math Tutoring</h3>
                <p class="card__intro">From early numeracy to advanced problem-solving, we make math meaningful and manageable. Our tutors break down complex concepts and help students:</p>
                <ul class="skill-list">
                  <li>Master core operations</li>
                  <li>Build number sense</li>
                  <li>Develop reasoning and critical thinking</li>
                </ul>
                <p class="card__foot">
                  We use clear instruction, practical examples, and positive reinforcement to turn
                  frustration into achievement.
                </p>
              </div>
            </article>

            <!-- Writing -->
            <article class="card" data-reveal data-delay="2">
              <div class="card__media">
                <img src={img('service-writing.jpg')} width="400" height="275"
                  alt="Close-up of a child writing with a colored pencil" />
              </div>
              <div class="card__body">
                <span class="card__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 4.5 19.5 9 9 19.5l-5 1.5 1.5-5L15 4.5Z"/><path d="m13 6.5 4.5 4.5"/></svg>
                </span>
                <h3>Writing Skills</h3>
                <p class="card__intro">Writing is more than putting words on paper — it's about organizing thoughts, communicating clearly, and developing a voice. We guide students through:</p>
                <ul class="skill-list">
                  <li>Sentence structure and grammar</li>
                  <li>Paragraph and essay organization</li>
                  <li>Creative and persuasive writing</li>
                </ul>
                <p class="card__foot">
                  Our goal? Confident, expressive young writers who can share their ideas with
                  clarity and purpose.
                </p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <svg class="wave" viewBox="0 0 1440 90" preserveAspectRatio="none" aria-hidden="true" style="color: var(--teal-800)">
        <path fill="currentColor" d="M0,55 C240,20 480,20 720,45 C960,70 1200,75 1440,45 L1440,90 L0,90 Z" />
      </svg>

      <!-- ===================== WHY FAMILIES CHOOSE US ===================== -->
      <section class="why section-pad on-dark" id="why">
        <div class="container why__grid">
          <div class="why__media" data-reveal>
            <img src={img('choose.jpg')} width="640" height="512"
              alt="An adult warmly helping a child with schoolwork at a table" />
          </div>
          <div class="why__text">
            <p class="eyebrow" data-reveal>The Osprey difference</p>
            <h2 data-reveal data-delay="1">Why Families Choose Us</h2>
            <ul class="features" data-reveal data-delay="1">
              <li class="feature">
                <span class="feature__ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m20 6-11 11-5-5"/></svg></span>
                <div><h3>Certified &amp; experienced</h3><p>Instruction from a credentialed educator who knows how children learn.</p></div>
              </li>
              <li class="feature">
                <span class="feature__ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m20 6-11 11-5-5"/></svg></span>
                <div><h3>1:1 &amp; small groups</h3><p>Flexible formats that fit your child and your family's schedule.</p></div>
              </li>
              <li class="feature">
                <span class="feature__ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m20 6-11 11-5-5"/></svg></span>
                <div><h3>Customized plans</h3><p>A learning plan built around each child's strengths and goals.</p></div>
              </li>
              <li class="feature">
                <span class="feature__ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m20 6-11 11-5-5"/></svg></span>
                <div><h3>Compassionate &amp; engaging</h3><p>A patient, encouraging approach that keeps learning positive.</p></div>
              </li>
            </ul>
            <p class="why__note" data-reveal data-delay="2">
              Whether your child needs support catching up, staying on track, or getting ahead,
              Osprey Learning Group is here to help every step of the way.
            </p>
          </div>
        </div>
      </section>

      <!-- ===================== FOUNDER ===================== -->
      <section class="founder section-pad" id="founder">
        <div class="container founder__grid">
          <div class="portrait" data-reveal>
            <div class="portrait__ph">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8.5A2.5 2.5 0 0 1 5.5 6h1l1-1.5h7l1 1.5h1A2.5 2.5 0 0 1 20 8.5v8A2.5 2.5 0 0 1 17.5 19h-11A2.5 2.5 0 0 1 4 16.5Z"/><circle cx="12" cy="12" r="3.2"/></svg>
              <div class="t">Photo coming soon</div>
              <div class="s">Nell Donato, Founder</div>
            </div>
          </div>
          <div class="founder__bio">
            <p class="eyebrow" data-reveal>Meet the Founder</p>
            <h2 class="founder__name" data-reveal data-delay="1">Nell Donato</h2>
            <p class="founder__role" data-reveal data-delay="1">Founder &amp; Lead Educator</p>
            <div class="pills" data-reveal data-delay="1">
              <span class="pill">17+ years teaching K–4</span>
              <span class="pill">M.A. Applied Linguistics (TESOL), Columbia</span>
              <span class="pill">Wilson Reading System</span>
              <span class="pill">Fundations</span>
              <span class="pill">Heggerty</span>
              <span class="pill">UFLI</span>
            </div>
            <div data-reveal data-delay="2">
              <p>
                Nell Donato has taught elementary students (K–4) for over 17 years, working with
                children from a variety of backgrounds and academic abilities. Nell holds a
                master's degree in Applied Linguistics (TESOL) from Columbia Teachers College and
                has continued her education in literacy instruction, including coursework in the
                Wilson Reading System.
              </p>
              <p>
                In her classroom, she provides daily instruction in phonics, phonemic awareness,
                encoding skills, fluency, and comprehension. Nell has extensive experience
                implementing the Wilson Fundations Curriculum, the Heggerty Phonemic Awareness
                Curriculum, and the University of Florida Literacy Institute (UFLI) Curriculum.
              </p>
              <blockquote class="founder__quote">
                For Nell, there is nothing more rewarding than seeing a child's face light up when
                all the threads of reading skills come together. The pride and confidence that come
                with fluent reading are truly magical — and she looks forward to helping your child
                discover that magic.
              </blockquote>
            </div>
          </div>
        </div>
      </section>

      <!-- ===================== CONTACT CTA ===================== -->
      <section class="contact section-pad on-dark" id="contact">
        <div class="container">
          <p class="eyebrow" data-reveal style="justify-content:center;">Let's get started</p>
          <h2 data-reveal data-delay="1">Schedule a free consultation</h2>
          <p class="lead" data-reveal data-delay="1">
            Contact us today to schedule a free consultation and discover how we can support your
            child's journey to academic success.
          </p>
          <div class="contact__cta" data-reveal data-delay="2">
            <a class="btn btn--primary" href={`mailto:${CONTACT_EMAIL}?subject=Free%20consultation%20request`}>Request your free consultation</a>
            <a class="btn btn--ghost" href="#services">See how we help</a>
          </div>
          <div class="contact__meta" data-reveal data-delay="2">
            <span><i class="dot"></i> Free initial consultation</span>
            <span><i class="dot"></i> One-on-one &amp; small group</span>
            <span><i class="dot"></i> Customized learning plans</span>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container footer__inner">
        <a class="brand" href="#top"><span class="mark"><Logo /></span> Osprey Learning Group</a>
        <ul class="footer__nav">
          <li><a href="#services">Services</a></li>
          <li><a href="#approach">Our Approach</a></li>
          <li><a href="#founder">About Nell</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
        <p class="footer__legal">© 2026 Osprey Learning Group. Specialized K–4 tutoring in reading, math &amp; writing.</p>
      </div>
    </footer>

    <script>
      // Staggered reveal on scroll
      const items = document.querySelectorAll('[data-reveal]');
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
          }
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.12 });
        items.forEach((el) => io.observe(el));
      } else {
        items.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
